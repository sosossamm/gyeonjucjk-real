{
  "rewrites": [
    {
      "source": "/share/:id",
      "destination": "/index.html"
    },
    {
      "source": "/reset-password",
      "destination": "/reset-password/index.html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
